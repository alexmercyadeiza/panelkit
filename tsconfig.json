{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": ".",
    "paths": {
      "@server/*": ["./server/*"],
      "@dashboard/*": ["./dashboard/src/*"]
    },
    "types": ["bun-types"]
  },
  "include": ["server/**/*.ts", "tests/**/*.ts"],
  "exclude": ["node_modules", "dist", "dashboard"]
}
